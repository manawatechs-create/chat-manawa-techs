# ============================================
# MANAWA TECHS - Configuration TEMPLATE
# ============================================
# Copiez ce fichier en .env et remplissez les valeurs
# ⚠️ NE JAMAIS COMMIT CE FICHIER .env DANS GIT !

# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5500

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=votre_user
DB_PASSWORD=votre_mot_de_passe
DB_NAME=manawa_techs

# Mistral AI - Obtenez votre clé sur https://console.mistral.ai/
MISTRAL_API_KEY=votre_cle_api_mistral

# Stability AI (optionnel) - https://platform.stability.ai/
STABILITY_API_KEY=votre_cle_stability

# JWT Secret - Générez avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=votre_secret_jwt_tres_long
JWT_EXPIRES_IN=7d

# Encryption key pour les clés API au repos
ENCRYPTION_KEY=votre_cle_chiffrement_32_caracteres
