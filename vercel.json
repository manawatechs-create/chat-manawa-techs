{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "runtime": "@vercel/node@22",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/frontend/$1" },
    { "source": "/", "destination": "/frontend/index.html" }
  ]
}
