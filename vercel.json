{
  "version": 2,
  "functions": {
    "api/manawa/chat.js": {
      "runtime": "@vercel/node@22",
      "maxDuration": 30
    },
    "api/manawa/post.js": {
      "runtime": "@vercel/node@22",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/manawa/chat", "destination": "/api/manawa/chat" },
    { "source": "/api/manawa/post", "destination": "/api/manawa/post" },
    { "source": "/(.*)", "destination": "/frontend/$1" },
    { "source": "/", "destination": "/frontend/index.html" }
  ]
}
